VITE_API_URL=http://localhost:3001/api/v1
VITE_WS_URL=ws://localhost:3001/ws
VITE_API_TIMEOUT_MS=30000

# Backend runtime foundations
DATABASE_URL=postgresql://axon:axon@localhost:5432/axon
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
AXON_API_BODY_LIMIT_BYTES=2097152
AXON_REGION=ap-south-1

# Durable local state and artifact fallback. Use object storage for multi-node production.
AXON_STATE_DIR=.axon/state
AXON_ARTIFACT_DIR=.axon/artifacts
AXON_ARTIFACT_DRIVER=local
AXON_S3_BUCKET=

# Trust Ledger signing. Production runtime requires a strong local secret plus managed KMS metadata.
AXON_LEDGER_SIGNING_KEY=replace-with-at-least-32-random-characters
AXON_KMS_KEY_ID=
AWS_KMS_KEY_ID=
GCP_KMS_KEY_NAME=
AZURE_KEY_VAULT_KEY_ID=

# Production adapters. Keep local defaults for development, set real adapters before customer launch.
AXON_DEPLOYMENT_ADAPTER=local-dry-run
AXON_BROWSER_WORKER_ENABLED=0
AXON_BROWSER_WORKER=
AXON_CONFIG_SECRET=
AXON_SSO_ISSUER_URL=
OIDC_ISSUER_URL=
AWS_SECRETS_MANAGER_SECRET_ID=
GCP_SECRET_MANAGER_PROJECT=
AZURE_KEY_VAULT_URL=

# Execution Fabric live adapters. Leave disabled unless you are intentionally submitting provider jobs.
AXON_ENABLE_DOCKER_RUN=false
AXON_DOCKER_COMMAND=
AXON_ENABLE_KUBERNETES_RUN=false
AXON_KUBE_NAMESPACE=default
GITHUB_TOKEN=
GITHUB_REPOSITORY=
AXON_GITHUB_WORKFLOW_ID=axon-execution-fabric.yml
AXON_GITHUB_REF=main
AXON_GITHUB_HEAD_BRANCH=
VERCEL_DEPLOY_HOOK_URL=
RENDER_DEPLOY_HOOK_URL=
RAILWAY_DEPLOY_HOOK_URL=
FLY_DEPLOY_HOOK_URL=
AXON_DEPLOY_HOOK_URL=
E2B_RUN_URL=
E2B_API_KEY=
DAYTONA_RUN_URL=
DAYTONA_API_KEY=
CODESPACES_RUN_URL=
FIRECRACKER_RUN_URL=
FIRECRACKER_API_KEY=
