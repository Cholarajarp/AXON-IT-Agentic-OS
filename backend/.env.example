PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
AXON_API_BODY_LIMIT_BYTES=2097152
DATABASE_URL=postgresql://axon:axon@localhost:5432/axon

# Register real model providers by setting one or more of these values.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://localhost:11434

# Sovereign / private-VPC providers
VLLM_BASE_URL=
VLLM_API_KEY=

# AWS Bedrock (optional sovereign route)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_CLAUDE_MODEL_ID=
BEDROCK_NOVA_MODEL_ID=

# Vertex AI (optional sovereign route)
GCP_PROJECT_ID=
GCP_LOCATION=

# Google AI Studio
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Force the deterministic mock provider on for eval/dev
MODEL_PROVIDER_MOCK=0

# Execution Fabric live adapters. Keep disabled until reviewed and approved.
AXON_ENABLE_DOCKER_RUN=false
AXON_DOCKER_COMMAND=
AXON_ENABLE_KUBERNETES_RUN=false
AXON_KUBE_NAMESPACE=default
GITHUB_TOKEN=
GITHUB_REPOSITORY=
AXON_GITHUB_WORKFLOW_ID=axon-execution-fabric.yml
AXON_GITHUB_REF=main
AXON_GITHUB_HEAD_BRANCH=
VERCEL_DEPLOY_HOOK_URL=
RENDER_DEPLOY_HOOK_URL=
RAILWAY_DEPLOY_HOOK_URL=
FLY_DEPLOY_HOOK_URL=
AXON_DEPLOY_HOOK_URL=
E2B_RUN_URL=
E2B_API_KEY=
DAYTONA_RUN_URL=
DAYTONA_API_KEY=
CODESPACES_RUN_URL=
FIRECRACKER_RUN_URL=
FIRECRACKER_API_KEY=
